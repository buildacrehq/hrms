# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://buildacre:buildacre_dev@localhost:5432/buildacre_workforce

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use long random strings in production (e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_characters_long
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Cloudflare R2 (photo storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=buildacre-punches
# Custom domain if you set one up in R2, otherwise leave blank
R2_PUBLIC_DOMAIN=

# ─── Firebase (FCM push notifications) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n, or use a file path instead
FIREBASE_PRIVATE_KEY=

# ─── OTP provider ────────────────────────────────────────────────────────────
# "console" = logs OTP to terminal (dev only, never production)
# "msg91"   = MSG91 (popular India SMS provider)
# "fast2sms" = Fast2SMS (cheapest India SMS)
OTP_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
FAST2SMS_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3001
# How long (seconds) a signed photo URL stays valid
SIGNED_URL_EXPIRY_SECONDS=300
# Photo retention: delete punch photos older than this many days (0 = disabled)
PHOTO_RETENTION_DAYS=730
